{
  "name": "daily-money",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "host": "npm run build && vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "ios:sync": "npm run build && cap sync ios",
    "reminders:dev": "wrangler dev --config workers/reminders/wrangler.jsonc --local",
    "reminders:deploy": "wrangler deploy --config workers/reminders/wrangler.jsonc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@fontsource/inter": "^5.2.8",
    "dexie": "^4.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.110.0"
  }
}
